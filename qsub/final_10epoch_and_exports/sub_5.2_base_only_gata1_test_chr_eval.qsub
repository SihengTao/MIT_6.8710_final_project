#!/bin/bash
#$ -N five2_gata1_base_test
#$ -cwd
#$ -l h_vmem=128G
#$ -l h_rt=48:00:00
#$ -l gpu=1
#$ -l os=RedHat8
#$ -hard
#$ -m ea
#$ -M stao@broadinstitute.org

set -euo pipefail

PROJECT_DIR="/broad/boxialab/sihengtao/chromnitron/chromnitron_finetune"
PYTHON="/broad/boxialab/sihengtao/env_all/chromnitron_gpu/bin/python"
EVAL_SCRIPT="${PROJECT_DIR}/scripts/eval_hic2_zero_shot.py"
CONFIG="${PROJECT_DIR}/configs/5.2finetuneidea/gata1_scratch_r4_lr1e4_10ep_2024paper.yaml"
OUTPUT_DIR="/broad/boxialab/sihengtao/projects/chromnitron_finetune/20260503_analysis/base_only_gata1_test_chr_eval_gpu"
LOG_DIR="/broad/boxialab/sihengtao/projects/chromnitron_finetune/logs"
JOB_ID_TAG="${JOB_ID:-manual}"
LOG_FILE="${LOG_DIR}/five2_gata1_base_test.${JOB_ID_TAG}.log"

mkdir -p "${LOG_DIR}" "${OUTPUT_DIR}"

exec > >(tee -a "${LOG_FILE}") 2>&1

finish() {
    status=$?
    echo "[$(date --iso-8601=seconds)] END five2_gata1_base_test status=${status}"
}
trap finish EXIT

echo "[$(date --iso-8601=seconds)] START five2_gata1_base_test"
echo "Host: $(hostname)"
echo "Job ID: ${JOB_ID_TAG}"
echo "Project dir: ${PROJECT_DIR}"
echo "Config: ${CONFIG}"
echo "Output dir: ${OUTPUT_DIR}"
echo "Python: ${PYTHON}"

cd "${PROJECT_DIR}"

"${PYTHON}" "${EVAL_SCRIPT}" \
    --config "${CONFIG}" \
    --mode base \
    --output-dir "${OUTPUT_DIR}" \
    --splits val,test \
    --label base_only_gata1_test_chr_eval
